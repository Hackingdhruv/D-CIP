# =============================================================================
# D-CIP — Environment configuration (example)
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# Every variable here is consumed by the backend Settings model and/or
# docker-compose. Validation happens at app startup (see app/core/config.py).
# =============================================================================

# --- Runtime -----------------------------------------------------------------
# One of: development | testing | production
DCIP_ENV=development
# Human-readable app metadata (surfaced on the /version endpoint).
APP_NAME=D-CIP
APP_VERSION=1.0.0
# When true, enables verbose errors, auto-reload and the OpenAPI docs UI.
DEBUG=true
LOG_LEVEL=INFO
# json | console — JSON is recommended for production log aggregation.
LOG_FORMAT=console

# --- API server --------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Public base path the API is mounted under (kept in sync with NGINX).
API_PREFIX=/api
API_V1_PREFIX=/api/v1

# --- Security ----------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# REQUIRED in production. Startup fails if left as the placeholder.
SECRET_KEY=change-me-in-production-use-a-64-byte-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080
# Cookie settings for the httpOnly auth cookies.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=localhost
AUTH_COOKIE_SAMESITE=lax

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins for the browser app.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# --- Rate limiting -----------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
# Storage for the limiter: memory:// (default) or a redis:// URL for multi-process.
RATE_LIMIT_STORAGE_URI=memory://

# --- PostgreSQL (system of record) -------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dcip
POSTGRES_PASSWORD=dcip_dev_password
POSTGRES_DB=dcip
# Optional explicit URL; if unset it is assembled from the parts above.
# DATABASE_URL=postgresql+psycopg://dcip:dcip_dev_password@localhost:5432/dcip
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Neo4j (relationship graph) ----------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dcip_neo4j_password
NEO4J_DATABASE=neo4j

# --- Redis (cache, queues, sessions) -----------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# REDIS_URL=redis://localhost:6379/0

# --- OpenSearch (full-text + semantic search) --------------------------------
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=dcip_opensearch_password
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false

# --- Celery worker -----------------------------------------------------------
# Default to Redis for both broker and result backend.
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# --- Uploads / Evidence storage ----------------------------------------------
UPLOAD_DIR=uploads
MAX_EVIDENCE_SIZE_MB=500

# --- AI provider (set AI_PROVIDER=openai to enable) -------------------------
AI_PROVIDER=none
AI_API_KEY=
AI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.1

# --- OCR (requires Tesseract installed on the host) --------------------------
OCR_ENABLED=true
# Path to tesseract binary; leave blank to use system PATH.
TESSERACT_CMD=

# --- OpenSearch indexing (opt-in; requires running OpenSearch) ---------------
OPENSEARCH_ENABLED=false

# --- Frontend (Vite reads only VITE_-prefixed vars) --------------------------
VITE_API_BASE_URL=http://localhost:8000/api
VITE_APP_NAME=D-CIP
