{
  "name": "@dcip/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "D-CIP web client (React 19 + Vite + TypeScript).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
